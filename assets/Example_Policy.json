  "rules" : [ {
    "name" : "Check Certificate Expiration",
    "description" : "Check the output of \"show crypto pki certificate\" and search for end dates that fall within the current month and year.",
    "impact" : "",
    "suggestedFix" : "",
    "softwareType" : "IOS_XE",
    "deviceTypes" : [ {
      "deviceFamily" : "Routers"
    }, {
      "deviceFamily" : "Wireless Controller"
    }, {
      "deviceFamily" : "Switches and Hubs"
    } ],
    "conditions" : [ {
      "scope" : "DEVICE_COMMAND_OUTPUT",
      "showCommand" : "show clock",
      "isBasicMode" : false,
      "blockViolationCriteria" : "ANY_BLOCK_OR_VALUE_VIOLATES",
      "oneViolationPerFailedBlock" : true,
      "operator" : "MATCHES_EXPRESSION",
      "regexViolationCriteria" : "ANY_BLOCK_OR_VALUE_VIOLATES",
