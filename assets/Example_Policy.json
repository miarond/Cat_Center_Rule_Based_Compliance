      "name" : "Output of 'show clock' must match the expression '^([\\d:\\.]+)\\s(\\w+)\\s(\\w+)\\s(\\w+)\\s(\\d+)\\s(\\d+)$'",
      "action" : {
        "matchAction" : "DO_NOT_RAISE_VIOLATION_AND_CONTINUE",
        "doesNotMatchAction" : "DO_NOT_RAISE_VIOLATION_AND_STOP"
      },
      "sequenceNumber" : 1
