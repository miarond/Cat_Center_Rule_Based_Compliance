      "name" : "Previously matched blocks must match the expression '^\\s*end\\s+date:\\s?([0-9:\\.]+)\\s(\\w+)\\s(\\w+)\\s(\\d+)\\s(\\d+)$'",
      "action" : {
        "matchAction" : "DO_NOT_RAISE_VIOLATION_AND_CONTINUE",
        "doesNotMatchAction" : "DO_NOT_RAISE_VIOLATION_AND_STOP"
      },
      "sequenceNumber" : 4
    }, {
      "scope" : "PREVIOUSLY_MATCHED_BLOCKS",
      "isBasicMode" : false,
      "blockViolationCriteria" : "ANY_BLOCK_OR_VALUE_VIOLATES",
      "oneViolationPerFailedBlock" : true,
      "operator" : "EVALUATE_EXPRESSION",
      "regexViolationCriteria" : "ANY_BLOCK_OR_VALUE_VIOLATES",
      "oneViolationPerFailedInstance" : true,
      "value" : "<4.3> matches <1.4> & <4.5> matches <1.6>",
      "id" : "849044f1-0280-4ad5-996a-e6999180ae5f",
